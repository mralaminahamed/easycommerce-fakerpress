{
  "name": "@mralaminahamed/easycommerce-fakerpress",
  "version": "1.0.0",
  "description": "Generate fake ecommerce data (orders, products, customers, coupons) for EasyCommerce plugin using PHPFaker library with modern React-based admin interface.",
  "main": "src/index.js",
  "scripts": {
    "build": "wp-scripts build",
    "start": "wp-scripts start",
    "dev": "wp-scripts start",
    "watch": "wp-scripts start",
    "lint:css": "wp-scripts lint-style src/**/*.scss",
    "lint:js": "wp-scripts lint-js src/**/*.js",
    "lint:php": "phpcs",
    "lint:php:fix": "phpcbf",
    "phpstan": "phpstan analyse",
    "format": "wp-scripts format src/**/*.js",
    "packages-update": "wp-scripts packages-update",
    "lint": "npm run lint:js && npm run lint:css && npm run lint:php",
    "fix": "wp-scripts format src/**/*.js && npm run lint:php:fix"
  },
  "keywords": [
    "wordpress",
    "plugin",
    "ecommerce",
    "woocommerce",
    "faker",
    "data-generation",
    "react",
    "admin-interface",
    "fake-data",
    "products",
    "customers",
    "orders",
    "coupons"
  ],
  "author": "Al Amin Ahamed <me@alaminahamed.com> (https://alaminahamed.com)",
  "license": "GPL-2.0-or-later",
  "homepage": "https://alaminahamed.com/projects/easycommerce-fakerpress",
  "repository": {
    "type": "git",
    "url": "https://github.com/mralaminahamed/easycommerce-fakerpress.git"
  },
  "bugs": {
    "url": "https://github.com/mralaminahamed/easycommerce-fakerpress/issues"
  },
  "devDependencies": {
    "@babel/core": "^7.28.0",
    "@playwright/test": "^1.54.2",
    "@wordpress/eslint-plugin": "^22.13.0",
    "@wordpress/scripts": "^30.20.0",
    "@wordpress/stylelint-config": "^23.19.0",
    "autoprefixer": "^10.4.21",
    "eslint": "8",
    "postcss": "^8.5.6",
    "prettier": "^3.6.2",
    "react": "18",
    "react-dom": "18",
    "sass": "^1.89.2",
    "sass-loader": "^16.0.5",
    "stylelint": "^16.23.0",
    "stylelint-config-prettier-scss": "^1.0.0",
    "stylelint-config-recess-order": "^7.1.0",
    "stylelint-config-tailwindcss": "^1.0.0",
    "stylelint-order": "^7.0.0",
    "stylelint-scss": "^6.12.1",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.7",
    "@heroicons/react": "^2.2.0",
    "@wordpress/api-fetch": "^7.27.0",
    "@wordpress/dom-ready": "^4.27.0",
    "@wordpress/element": "^6.27.0",
    "@wordpress/i18n": "^6.0.0"
  },
  "browserslist": [
    "extends @wordpress/browserslist-config"
  ],
  "packageManager": "yarn@4.9.2"
}
