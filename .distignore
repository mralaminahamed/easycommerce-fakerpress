# ============================================================
# .distignore — files excluded from WordPress.org SVN deploy
# The 10up deploy action uses this to filter what goes to SVN.
# build/ is intentionally NOT excluded (compiled assets needed).
# ============================================================

# Source code (compiled output in build/ is what SVN gets)
/src/

# Documentation (GitHub-only; readme.txt is the WP.org doc)
*.md
/docs/
/drafts/

# Node / JS toolchain
/node_modules/
/.yarn/
package.json
package-lock.json
yarn.lock
webpack.config.js
postcss.config.js
tailwind.config.js
.babelrc
.eslintrc.js
.eslintrc.json
.eslintcache
tsconfig.json
tsconfig.*.json

# PHP toolchain & static analysis
composer.json
composer.lock
phpcs.xml
phpcs.plugin-review.xml
phpstan.neon
phpstan.neon.dist
phpunit.xml
phpunit.xml.dist
/.phpstan-cache/

# Code style
.stylelintrc.js
.stylelintrc.json
.stylelintcache
.editorconfig
.prettierrc
.prettierrc.js
.prettierrc.json

# Testing & CI
/tests/
playwright.config.ts
.github/
.travis.yml
.circleci/
/coverage/
/test-results/
/.phpunit.result.cache

# WordPress.org assets (go to assets/ SVN path, not plugin trunk)
/.wordpress-org/

# Release artifacts
/release/
/dist/

# Git
/.git/
.gitignore
.gitattributes
.gitmodules

# Environment & secrets
.env
.env.*
.env.local

# Claude AI / AI agent files
/.claude/
CLAUDE.md
AGENTS.md

# Misc project config
components.json
opencode.json
.actrc
.ncurc.json
.yarnrc.yml

# IDE & OS
/.vscode/
/.idea/
*.sublime-project
*.sublime-workspace
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# Temporary & caches
*.tmp
*.log
*.cache
*.swp
*.swo
*~
/.cache/
/tmp/
.parcel-cache/
.nyc_output/

# Archives (dev-generated)
*.zip
*.tar.gz
*.tar
*.tgz
*.rar

# Self
.distignore
