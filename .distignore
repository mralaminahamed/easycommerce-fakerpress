# ============================================================
# .distignore — files excluded from WordPress.org SVN deploy
#
# What SHIPS to SVN (plugin trunk):
#   easycommerce-fakerpress.php  class-easycommerce-fakerpress.php
#   includes/   vendor/   build/   languages/   readme.txt   LICENSE
#
# Everything else listed here is dev-only and must NOT ship.
# build/ is intentionally absent from this list — compiled
# JS/CSS assets are required for the plugin to function.
# ============================================================

# ── Source code ───────────────────────────────────────────────
# Compiled output lives in build/ which ships; raw source does not.
/src/

# ── Documentation (GitHub-only) ───────────────────────────────
# readme.txt is the canonical WP.org doc; .md files are for GitHub.
*.md
/docs/

# ── Node / JavaScript toolchain ───────────────────────────────
/node_modules/
/.yarn/
package.json
package-lock.json
yarn.lock
.yarnrc.yml
webpack.config.js
postcss.config.js
tsconfig.json
.eslintrc.js
.eslintcache
.stylelintrc.js
.stylelintcache

# ── PHP toolchain & static analysis ───────────────────────────
composer.json
composer.lock
phpcs.xml
phpcs.plugin-review.xml
phpstan.neon
phpunit.xml.dist
/.phpstan-cache/
.phpunit.result.cache

# ── Testing ───────────────────────────────────────────────────
/tests/
/test-results/
playwright.config.ts

# ── CI / GitHub Actions ───────────────────────────────────────
/.github/

# ── WordPress.org assets ──────────────────────────────────────
# Banners, icons, and screenshots are deployed to the separate
# SVN assets/ path by the 10up action; they must not go to trunk.
/.wordpress-org/

# ── AI / agent tooling ────────────────────────────────────────
/.claude/
/.playwright-mcp/
/.remember/

# ── IDE & editor ──────────────────────────────────────────────
/.idea/
/.vscode/
.editorconfig

# ── Misc project config (not needed at runtime) ───────────────
components.json
opencode.json
.actrc
.ncurc.json

# ── Git ───────────────────────────────────────────────────────
/.git/
.gitignore
.gitattributes

# ── Environment & secrets ─────────────────────────────────────
.env
.env.*

# ── OS noise ──────────────────────────────────────────────────
.DS_Store
Thumbs.db
._*

# ── Temporary / caches ────────────────────────────────────────
*.log
*.cache
*.swp
*~

# ── Self ──────────────────────────────────────────────────────
.distignore
