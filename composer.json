{
    "name": "mralaminahamed/easycommerce-fakerpress",
    "description": "Generate fake ecommerce data (orders, products, customers, coupons) for EasyCommerce plugin using PHPFaker library with modern React-based admin interface.",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Al Amin Ahamed",
            "email": "me@alaminahamed.com",
            "homepage": "https://alaminahamed.com"
        }
    ],
    "homepage": "https://alaminahamed.com/projects/easycommerce-fakerpress",
    "support": {
        "issues": "https://github.com/mralaminahamed/easycommerce-fakerpress/issues",
        "source": "https://github.com/mralaminahamed/easycommerce-fakerpress"
    },
    "require": {
        "php": ">=7.4",
        "fakerphp/faker": "^1.23"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.2",
        "phpcompatibility/php-compatibility": "^9.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.1",
        "php-stubs/wordpress-stubs": "^6.4",
        "php-stubs/woocommerce-stubs": "^8.3",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "optimize-autoloader": true,
        "classmap-authoritative": true
    },
    "autoload": {
        "classmap": [
            "class-easycommerce-fakerpress.php"
        ],
        "psr-4": {
            "EasyCommerceFakerPress\\": "includes/"
        }
    },
    "scripts": {
        "phpcs": "phpcs",
        "phpcbf": "phpcbf",
        "phpstan": "phpstan analyse",
        "lint": "phpcs",
        "fix": "phpcbf"
    }
}