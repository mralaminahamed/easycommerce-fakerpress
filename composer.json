{
    "name": "easycommerce/fakerpress",
    "description": "Generate fake ecommerce data for EasyCommerce plugin",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Your Name",
            "email": "your.email@example.com"
        }
    ],
    "require": {
        "php": "^7.4",
        "fakerphp/faker": "^1.23"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "squizlabs/php_codesniffer": "^3.7",
        "wp-coding-standards/wpcs": "^3.0",
        "phpcompatibility/php-compatibility": "^9.3"
    },
    "autoload": {
        "psr-4": {
            "EasyCommerceFakerPress\\": "includes/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "fix": "phpcbf",
        "compatibility": "phpcs --standard=PHPCompatibility includes/ easycommerce-fakerpress.php"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        },
        "platform": {
            "php": "7.4"
        }
    }
}