{
    "name": "mralaminahamed/easycommerce-fakerpress",
    "description": "Comprehensive EasyCommerce test data generator with 11 specialized generators, real-time validation, advanced parameter configuration, WordPress admin color integration, and modern React Router v7 interface.",
    "license": "GPL-2.0-or-later",
    "type": "wordpress-plugin",
    "authors": [
        {
            "name": "Al Amin Ahamed",
            "email": "me@alaminahamed.com",
            "homepage": "https://github.com/mralaminahamed/"
        }
    ],
    "keywords": [
        "wordpress",
        "woocommerce",
        "easycommerce",
        "faker",
        "test-data",
        "sample-data",
        "generator"
    ],
    "homepage": "https://github.com/mralaminahamed/easycommerce-fakerpress",
    "support": {
        "issues": "https://github.com/mralaminahamed/easycommerce-fakerpress/issues",
        "source": "https://github.com/mralaminahamed/easycommerce-fakerpress"
    },
    "require": {
        "php": ">=7.4",
        "ext-json": "*",
        "bluemmb/faker-picsum-photos-provider": "^2.0",
        "fakerphp/faker": "^1.23"
    },
    "require-dev": {
        "brain/monkey": "^2.6",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.0",
        "ergebnis/composer-normalize": "^2.50",
        "php-stubs/wordpress-stubs": "^6.4",
        "phpcompatibility/phpcompatibility-wp": "^2.1",
        "phpstan/extension-installer": "^1.4",
        "phpstan/phpstan": "^2.1",
        "phpunit/phpunit": "^9.6",
        "squizlabs/php_codesniffer": "^3.7",
        "szepeviktor/phpstan-wordpress": "^2.0",
        "wp-coding-standards/wpcs": "^3.1",
        "wp-phpunit/wp-phpunit": "^6.8",
        "yoast/phpunit-polyfills": "^4.0"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "EasyCommerceFakerPress\\": "includes/"
        },
        "classmap": [
            "class-easycommerce-fakerpress.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "EasyCommerceFakerPress\\Tests\\": "tests/php/src/"
        }
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true,
            "ergebnis/composer-normalize": true,
            "phpstan/extension-installer": true
        },
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "platform": {
            "php": "7.4"
        }
    },
    "scripts": {
        "github:svn:test": "act push --eventpath .github/act-tag-event.json -W ./.github/workflows/svn-deploy.yml",
        "makepot": "wp i18n make-pot . languages/easycommerce-fakerpress.pot --exclude=node_modules,vendor,drafts,docs,build,release,tests",
        "phpcbf":  "phpcbf --standard=phpcs.xml",
        "phpcbf:plugin-review": "phpcbf --standard=phpcs.plugin-review.xml",
        "phpcs":  "phpcs --standard=phpcs.xml",
        "phpcs:plugin-review":  "phpcs --standard=phpcs.plugin-review.xml",
        "phpstan": "phpstan analyse --memory-limit 2G",
        "lint": "@phpcs",
        "analyse": "@phpstan",
        "release": [
            "@lint",
            "@analyse",
            "rm -rf release vendor build/*",
            "yarn build",
            "@makepot",
            "mkdir -p release",
            "composer install --no-dev --optimize-autoloader",
            "rsync -av --exclude-from=.distignore . release/easycommerce-fakerpress/",
            "cd release && zip -r easycommerce-fakerpress.zip easycommerce-fakerpress/",
            "composer install"
        ],
        "test": "phpunit",
        "test:coverage": "phpunit --coverage-html=tests/coverage/html"
    }
}
